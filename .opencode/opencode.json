{
  "$schema": "https://opencode.ai/config.json",
  "description": "OpenCode configuration for macOS dotfiles project",
  "instructions": [
    "AGENTS.md",
    ".opencode/prompts/base.txt"
  ],
  "permission": {
    "read": "allow",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "ask",
    "task": "allow",
    "external_directory": "deny",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "deny",
    "lsp": "allow",
    "skill": "allow",
    "question": "allow"
  },
  "agent": {
    "dot": {
      "mode": "subagent",
      "description": "Specialist agent for macOS dotfiles: validates configs, manages ZSH/Tmux/Neovim, handles installation workflows",
      "temperature": 0.2,
      "steps": 15,
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "deny",
          "make *": "allow",
          "make verify": "allow",
          "make profile": "allow",
          "make help": "allow",
          "zsh -n *": "allow",
          "tmux source-file -v *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git branch": "allow",
          "bash scripts/validate-configs.sh": "allow"
        }
      }
    }
  }
}
