#!/bin/bash
# Generate random passwords

LENGTH=${1:-16}

if ! [[ "$LENGTH" =~ ^[0-9]+$ ]] || [ "$LENGTH" -lt 8 ] || [ "$LENGTH" -gt 128 ]; then
    echo "Usage: passwdgen [length]"
    echo "  length: 8-128 (default: 16)"
    exit 1
fi

# Generate password using openssl
PASSWORD=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9!@#$%^&*' | head -c "$LENGTH")

echo "Password ($LENGTH chars): $PASSWORD"
