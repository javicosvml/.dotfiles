#!/bin/bash
# Verify dotfiles installation status on macOS

echo "========================================"
echo "  Dotfiles Installation Verification"
echo "========================================"
echo ""

# Color codes
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

check_command() {
    if command -v "$1" &>/dev/null; then
        echo -e "${GREEN}✓${NC} $1 is installed"
        if [ -n "$2" ]; then
            echo "  └─ $($1 $2 2>&1 | head -1)"
        fi
        return 0
    else
        echo -e "${RED}✗${NC} $1 is NOT installed"
        return 1
    fi
}

check_file() {
    if [ -e "$1" ]; then
        echo -e "${GREEN}✓${NC} $1 exists"
        return 0
    else
        echo -e "${RED}✗${NC} $1 NOT found"
        return 1
    fi
}

echo "--- System Prerequisites ---"
check_command "brew" "--version"
check_command "git" "--version"
check_command "make" "--version | head -1"
echo ""

echo "--- ASDF Version Manager ---"
check_file "$HOME/.asdf"
if [ -f "$HOME/.asdf/asdf.sh" ]; then
    source "$HOME/.asdf/asdf.sh"
    check_command "asdf" "version"
fi
echo ""

echo "--- Shell Configuration ---"
check_file "$HOME/.zshrc"
check_file "$HOME/.zsh.d"
check_file "$HOME/.zsh.d/alias.zsh"
check_file "$HOME/.zsh.d/tools.zsh"
echo ""

echo "--- Editor Configuration ---"
check_file "$HOME/.vimrc"
check_file "$HOME/.config/nvim/init.vim"
check_command "nvim" "--version | head -1"
echo ""

echo "--- Terminal Multiplexer ---"
check_file "$HOME/.tmux.conf"
check_file "$HOME/.tmux.conf.local"
check_command "tmux" "-V"
echo ""

echo "--- Optional Tools ---"
check_command "bat" "--version | head -1"
check_command "lsd" "--version"
check_command "fzf" "--version"
check_command "kubectl" "version --client --short 2>&1 | head -1"
check_command "helm" "version --short"
check_command "terraform" "version | head -1"
echo ""

echo "--- Zinit Plugin Manager ---"
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
check_file "$ZINIT_HOME"
echo ""

echo "========================================"
echo "  Verification Complete"
echo "========================================"
echo ""
echo "If you see any missing items marked with ${RED}✗${NC}:"
echo "  1. Run: ./scripts/macos-setup (for prerequisites)"
echo "  2. Run: make asdf (for ASDF)"
echo "  3. Run: make profile (for shell/editor configs)"
echo "  4. Run: make tools (for development tools)"
echo ""
