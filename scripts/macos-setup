#!/bin/bash
# macOS Setup Script - Install prerequisites for dotfiles
# Compatible with ASDF v0.18.0+

set -e

# Colors
BOLD=$(tput bold)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
RED=$(tput setaf 1)
RESET=$(tput sgr0)

echo "========================================"
echo "  macOS Dotfiles Prerequisites Setup"
echo "  ASDF v0.18.0+ Compatible"
echo "========================================"
echo ""

# Check if running on macOS
if [[ "$OSTYPE" != "darwin"* ]]; then
    echo "${RED}Error: This script is designed for macOS only.${RESET}"
    exit 1
fi

echo "${BOLD}System Information:${RESET}"
echo "  macOS Version: $(sw_vers -productVersion)"
echo "  Architecture: $(uname -m)"
echo ""

# Install Homebrew if not present
if ! command -v brew &>/dev/null; then
    echo "${YELLOW}Installing Homebrew...${RESET}"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    
    # Add Homebrew to PATH based on architecture
    if [[ $(uname -m) == "arm64" ]]; then
        echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> ~/.zprofile
        eval "$(/opt/homebrew/bin/brew shellenv)"
        echo "${GREEN}✓ Homebrew installed (Apple Silicon)${RESET}"
    else
        echo 'eval "$(/usr/local/bin/brew shellenv)"' >> ~/.zprofile
        eval "$(/usr/local/bin/brew shellenv)"
        echo "${GREEN}✓ Homebrew installed (Intel)${RESET}"
    fi
else
    echo "${GREEN}✓ Homebrew already installed at $(which brew)${RESET}"
    echo "  Version: $(brew --version | head -n 1)"
fi

# Update Homebrew
echo ""
echo "${YELLOW}Updating Homebrew...${RESET}"
brew update --quiet 2>/dev/null || brew update
echo "${GREEN}✓ Homebrew updated${RESET}"

# Install essential tools
echo ""
echo "${BOLD}Installing essential tools...${RESET}"

# Essential packages with descriptions
declare -A PACKAGES=(
    ["git"]="Version control system"
    ["tmux"]="Terminal multiplexer"
    ["neovim"]="Modern Vim-based editor"
    ["wget"]="Network downloader"
    ["curl"]="URL transfer tool"
    ["jq"]="JSON processor"
    ["yq"]="YAML processor"
    ["coreutils"]="GNU core utilities"
    ["bat"]="Better cat with syntax highlighting"
    ["lsd"]="Better ls with icons"
    ["fd"]="Better find"
    ["ripgrep"]="Better grep"
    ["fzf"]="Fuzzy finder"
    ["tree"]="Directory tree viewer"
    ["htop"]="Better top"
    ["tldr"]="Simplified man pages"
)

INSTALLED=0
SKIPPED=0

for package in "${!PACKAGES[@]}"; do
    if brew list "$package" &>/dev/null 2>&1; then
        echo "${GREEN}✓${RESET} $package - ${PACKAGES[$package]}"
        ((SKIPPED++))
    else
        echo "${YELLOW}Installing $package...${RESET}"
        if brew install "$package" --quiet 2>/dev/null || brew install "$package"; then
            echo "${GREEN}✓${RESET} $package installed"
            ((INSTALLED++))
        else
            echo "${RED}✗${RESET} Failed to install $package"
        fi
    fi
done

echo ""
echo "${GREEN}Summary: $INSTALLED installed, $SKIPPED already present${RESET}"

# Note: Docker, kubectl, helm, and language runtimes are installed via ASDF
# This ensures consistent version management across all development tools

echo ""
echo "${GREEN}========================================${RESET}"
echo "${GREEN}${BOLD}  Prerequisites installation complete!${RESET}"
echo "${GREEN}========================================${RESET}"
echo ""
echo "${BOLD}Next steps (from ~/.dotfiles directory):${RESET}"
echo ""
echo "  ${YELLOW}1.${RESET} Install ASDF version manager (v0.18.0+):"
echo "     ${GREEN}make asdf${RESET}"
echo "     ${GREEN}source ~/.zshrc${RESET}"
echo ""
echo "  ${YELLOW}2.${RESET} Install shell and editor configurations:"
echo "     ${GREEN}make profile${RESET}"
echo ""
echo "  ${YELLOW}3.${RESET} Install development tools via ASDF:"
echo "     ${GREEN}cd tools && make help${RESET}     # See available tools"
echo "     ${GREEN}cd tools && make all${RESET}      # Install essentials (Python, Node.js, etc.)"
echo "     ${GREEN}cd tools && make all-tools${RESET} # Interactive selection"
echo ""
echo "  ${YELLOW}4.${RESET} (Optional) Install Kitty terminal:"
echo "     ${GREEN}make kitty${RESET}"
echo ""
echo "  ${YELLOW}5.${RESET} Verify installation:"
echo "     ${GREEN}./scripts/verify-setup${RESET}"
echo ""
echo "${YELLOW}For help at any time, run: make help${RESET}"
echo ""
