# ============================================================================
# PROMPT CONFIGURATION EXAMPLE
# ============================================================================
# Copy this file to ~/.zsh.d/prompt.config and edit to customize your prompt
# Source it BEFORE prompt.zsh in your ~/.zshrc
#
# Usage:
#   1. cp ~/.zsh.d/prompt.config.example ~/.zsh.d/prompt.config
#   2. Edit ~/.zsh.d/prompt.config with your preferences
#   3. In ~/.zshrc, add before sourcing prompt.zsh:
#      [[ -f "${ZSH_CONFIG_DIR}/prompt.config" ]] && source "${ZSH_CONFIG_DIR}/prompt.config"
#
# Color reference: https://upload.wikimedia.org/wikipedia/commons/1/15/Xterm_256color_chart.svg
# ============================================================================

# ----------------------------------------------------------------------------
# COLOR SCHEME
# ----------------------------------------------------------------------------
# Use ZSH color codes: 0-255 or named colors like 'red', 'blue', 'cyan', etc.

# Directory path color
typeset -g PROMPT_COLOR_DIR=31              # cyan (default)
# typeset -g PROMPT_COLOR_DIR=39            # white
# typeset -g PROMPT_COLOR_DIR=111           # light blue

# Git branch color
typeset -g PROMPT_COLOR_GIT_BRANCH=76       # bright green (default)
# typeset -g PROMPT_COLOR_GIT_BRANCH=111    # light blue

# Git status brackets color (when repository is clean)
typeset -g PROMPT_COLOR_GIT_CLEAN=31        # cyan (default)
# typeset -g PROMPT_COLOR_GIT_CLEAN=240     # gray

# Git status indicators
typeset -g PROMPT_COLOR_GIT_STAGED=76       # bright green (default)
typeset -g PROMPT_COLOR_GIT_UNSTAGED=178    # yellow/orange (default)
typeset -g PROMPT_COLOR_GIT_UNTRACKED=160   # red (default)
typeset -g PROMPT_COLOR_GIT_ACTION=160      # red for rebase/merge/etc (default)

# Command success/error indicators
typeset -g PROMPT_COLOR_SUCCESS=70          # green (default)
typeset -g PROMPT_COLOR_ERROR=160           # red (default)

# Prompt arrow color
typeset -g PROMPT_COLOR_ARROW=white         # white (default)
# typeset -g PROMPT_COLOR_ARROW=39          # default foreground

# Python virtualenv color
typeset -g PROMPT_COLOR_VIRTUALENV=37       # cyan light (default)

# Kubernetes context color
typeset -g PROMPT_COLOR_KUBECTL=134         # magenta/pink (default)

# ----------------------------------------------------------------------------
# SYMBOLS AND CHARACTERS
# ----------------------------------------------------------------------------

# Main prompt arrow (at the end of the prompt)
typeset -g PROMPT_SYMBOL_ARROW="❯"          # single arrow (default)
# typeset -g PROMPT_SYMBOL_ARROW="›"        # single chevron
# typeset -g PROMPT_SYMBOL_ARROW="→"        # right arrow
# typeset -g PROMPT_SYMBOL_ARROW="$"        # classic dollar sign
# typeset -g PROMPT_SYMBOL_ARROW="λ"        # lambda (for functional programming fans)

# Command status indicators
typeset -g PROMPT_SYMBOL_SUCCESS="✓"        # check mark (default)
# typeset -g PROMPT_SYMBOL_SUCCESS="✔"      # heavy check mark
# typeset -g PROMPT_SYMBOL_SUCCESS="●"      # circle

typeset -g PROMPT_SYMBOL_ERROR="✗"          # cross mark (default)
# typeset -g PROMPT_SYMBOL_ERROR="✘"        # heavy cross mark
# typeset -g PROMPT_SYMBOL_ERROR="●"        # circle

# Git status indicators
typeset -g PROMPT_SYMBOL_GIT_STAGED="●"     # staged changes (default)
# typeset -g PROMPT_SYMBOL_GIT_STAGED="✚"   # plus sign
# typeset -g PROMPT_SYMBOL_GIT_STAGED="+"   # simple plus

typeset -g PROMPT_SYMBOL_GIT_UNSTAGED="●"   # unstaged changes (default)
# typeset -g PROMPT_SYMBOL_GIT_UNSTAGED="✱" # asterisk
# typeset -g PROMPT_SYMBOL_GIT_UNSTAGED="*" # simple asterisk

typeset -g PROMPT_SYMBOL_GIT_UNTRACKED="…"  # untracked files (default)
# typeset -g PROMPT_SYMBOL_GIT_UNTRACKED="?" # question mark
# typeset -g PROMPT_SYMBOL_GIT_UNTRACKED="○" # hollow circle

# Kubernetes indicator
typeset -g PROMPT_SYMBOL_KUBECTL="☸"        # kubernetes wheel (default)
# typeset -g PROMPT_SYMBOL_KUBECTL="⎈"      # helm/wheel alternative
# typeset -g PROMPT_SYMBOL_KUBECTL="k8s"    # text

# ----------------------------------------------------------------------------
# DISPLAY OPTIONS
# ----------------------------------------------------------------------------

# Show git status (true/false)
typeset -g PROMPT_SHOW_GIT=true             # show git info (default)
# typeset -g PROMPT_SHOW_GIT=false          # hide git info

# Show Python virtualenv indicator (true/false)
typeset -g PROMPT_SHOW_VIRTUALENV=true      # show virtualenv (default)
# typeset -g PROMPT_SHOW_VIRTUALENV=false   # hide virtualenv

# Show kubectl context (true/false)
typeset -g PROMPT_SHOW_KUBECTL=true         # show kubectl context (default)
# typeset -g PROMPT_SHOW_KUBECTL=false      # hide kubectl context

# Note: Command status indicator (✓/✗) is always shown but does NOT display
# the exit code number. It only shows a visual indicator of success/failure.

# ----------------------------------------------------------------------------
# PRESET THEMES
# ----------------------------------------------------------------------------
# Uncomment one of these sections to use a preset theme

## Theme: Minimal (clean, simple, monochrome)
# typeset -g PROMPT_COLOR_DIR=white
