# Git Configuration
# Symlinked to ~/.gitconfig

[user]
	# Set these in ~/.gitconfig.local for personal info
	# name = Your Name
	# email = your.email@example.com

[include]
	# Include local config for machine-specific settings (user, signing keys, etc.)
	path = ~/.gitconfig.local

[init]
	defaultBranch = main

[core]
	editor = nvim
	pager = less -FRX
	autocrlf = input
	whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
	excludesFile = ~/.gitignore_global

[color]
	ui = auto
	branch = auto
	diff = auto
	status = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = green
	changed = yellow
	untracked = red

[pull]
	rebase = true

[push]
	default = current
	autoSetupRemote = true
	followTags = true

[fetch]
	prune = true
	pruneTags = true

[merge]
	conflictstyle = diff3
	tool = nvim

[mergetool "nvim"]
	cmd = nvim -d $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'

[diff]
	algorithm = histogram
	colorMoved = default
	tool = nvim

[difftool "nvim"]
	cmd = nvim -d $LOCAL $REMOTE

[rebase]
	autoStash = true
	autoSquash = true

[rerere]
	enabled = true

[help]
	autocorrect = prompt

[status]
	showUntrackedFiles = all

[log]
	abbrevCommit = true
	date = relative

[format]
	pretty = format:%C(auto)%h %C(blue)%ad %C(green)%an%C(auto)%d %s

[alias]
	# Status and info
	s = status -sb
	st = status
	info = remote show origin

	# Branches
	b = branch -v
	ba = branch -av
	bd = branch -d
	bD = branch -D
	co = checkout
	cob = checkout -b
	main = checkout main
	master = checkout master

	# Commits
	c = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit

	# Adding
	a = add
	aa = add --all
	ap = add --patch

	# Diff
	d = diff
	ds = diff --staged
	dc = diff --cached
	dl = diff HEAD~1

	# Log
	l = log --oneline -20
	lg = log --oneline --graph --all -20
	ll = log --graph --pretty=format:'%C(auto)%h%d %s %C(blue)(%cr) %C(green)<%an>'
	lp = log -p
	last = log -1 HEAD --stat

	# Push/Pull
	p = push
	pf = push --force-with-lease
	pl = pull
	f = fetch --all --prune

	# Stash
	ss = stash
	sp = stash pop
	sl = stash list
	sd = stash drop

	# Reset
	unstage = reset HEAD --
	undo = reset --soft HEAD~1
	hard = reset --hard HEAD
	hardundo = reset --hard HEAD~1

	# Cleanup
	cleanup = "!git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d"

	# Utilities
	aliases = config --get-regexp alias
	contributors = shortlog -sn --no-merges
	whoami = config user.email
	root = rev-parse --show-toplevel

[credential]
	helper = osxkeychain

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
